# ============================================================
#  Dulce Turquesa - Configuracion de entorno
#  Copia este archivo como .env y ajusta los valores
# ============================================================

APP_NAME=Dulce Turquesa API
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Genera una clave segura con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esta-clave-en-produccion

# ── Opcion A: SQL Server local con Windows Auth (sin contrasena) ──
# DATABASE_URL=mssql+pyodbc://localhost/DulceTurquesa?driver=ODBC+Driver+17+for+SQL+Server&trusted_connection=yes&TrustServerCertificate=yes

# ── Opcion B: SQL Server local con usuario y contrasena ──
DATABASE_URL=mssql+pyodbc://sa:TuPassword123@localhost/DulceTurquesa?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes

# ── Opcion C: SQL Server Express (instancia nombrada) ──
# DATABASE_URL=mssql+pyodbc://localhost\SQLEXPRESS/DulceTurquesa?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes

# ── Opcion D: Azure SQL ──
# DATABASE_URL=mssql+pyodbc://usuario@servidor:Password@servidor.database.windows.net/DulceTurquesa?driver=ODBC+Driver+17+for+SQL+Server

# ── Opcion E: SQLite (pruebas rapidas sin SQL Server) ──
# DATABASE_URL=sqlite:///./dulce_turquesa.db
